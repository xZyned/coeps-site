APP_BASE_URL=http://localhost:30001
AUTH0_DOMAIN=your-tenant.us.auth0.com
AUTH0_CLIENT_ID=your-auth0-client-id
AUTH0_CLIENT_SECRET=your-auth0-client-secret
AUTH0_SECRET=replace-with-a-32-byte-hex-secret

MONGODB_URI=mongodb+srv://username:password@cluster.example/database
MONGODB_DB=your-database-name
maxPoolSizeValue=100

ASAAS_API_KEY=your-asaas-api-key
ASAAS_API_URL=https://api-sandbox.asaas.com/v3
ASAAS_URL_CALLBACK=http://localhost:30001/pagamentos
ASAAS_URL_REDIRECT=http://localhost:30001/pagamentos

BLOB_READ_WRITE_TOKEN=your-vercel-blob-token
BLOB_TRABALHOS_READ_WRITE_TOKEN=your-vercel-blob-token
r2_access_key=your-r2-access-key
r2_secret_key=your-r2-secret-key
r2_bucket_name=your-r2-bucket
r2_endpoint_url=https://account-id.r2.cloudflarestorage.com
